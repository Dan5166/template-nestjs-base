# Test environment overrides (loaded before .env when NODE_ENV=test).
# Uses a separate database with schema auto-sync so e2e tests are self-contained.
NODE_ENV=test

DB_DATABASE=template_test
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Deterministic secrets for tests (never used in real environments).
JWT_ACCESS_SECRET=test_access_secret_at_least_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_refresh_secret_at_least_16_chars
JWT_REFRESH_EXPIRES_IN=7d

# Effectively disable rate limiting during tests.
THROTTLE_LIMIT=100000

# Quiet logs while testing.
LOG_LEVEL=silent
LOG_PRETTY=false

OAUTH_ENABLED=false
